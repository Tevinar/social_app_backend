# Local development environment variables for the backend
# Only put variables here that are specific to local development 
# and should not be used in other environments.

# Define the environment as 'local' to enable local development settings.
NODE_ENV=local

# Logging configuration
# possible values: debug, info, warn, error
LOG_LEVEL=debug

# Server configuration
PORT=3000
API_BASE_URL=http://localhost:3000

# Database configuration
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=social_app
POSTGRES_USER=social_app_user

# GCS configuration
GCS_BUCKET_NAME=social-app-dev

# Google Cloud global configuration
GOOGLE_CLOUD_PROJECT_ID=local-dev

# Fake GCS configuration
FAKE_GCS_HOST=127.0.0.1
FAKE_GCS_PORT=4443

# Pub/Sub emulator configuration
PUBSUB_EMULATOR_HOST=127.0.0.1:8085

# Authentication configuration
AUTH_ACCESS_TTL_MINUTES=60
AUTH_REFRESH_TTL_DAYS=30
