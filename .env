# Application configuration
# possible values: local, development, production
NODE_ENV=local

# Logging configuration
# possible values: debug, info, warn, error
LOG_LEVEL=debug

# Server configuration
PORT=3000
API_BASE_URL=http://localhost:3000

# Database configuration
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=social_app
POSTGRES_USER=social_app_user

# Google Cloud Storage configuration
GCS_PROJECT_ID=local-dev
GCS_BUCKET_NAME=social-app-dev
GCS_HOST=127.0.0.1
GCS_PORT=4443

# Authentication configuration
AUTH_ACCESS_TTL_MINUTES=60
AUTH_REFRESH_TTL_DAYS=30

# Kafka configuration
# Comma-separated list of Kafka broker addresses (e.g., localhost:9092,localhost:9093)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Use PLAINTEXT for local/development environments
# Use SASL_SSL for staging/production environments
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
