{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "docker: infra up",
      "type": "shell",
      "command": "docker compose --env-file .env up -d postgres fake-gcs",
      "problemMatcher": []
    },
    {
      "label": "pubsub: emulator start",
      "type": "shell",
      "command": "gcloud beta emulators pubsub start --project=social-app-local --host-port=127.0.0.1:8085",
      "isBackground": true,
      "problemMatcher": {
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Server started, listening on 8085"
        },
        "pattern": {
          "regexp": "."
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "pubsub: topics init",
      "type": "shell",
      "command": "npm run pubsub:init-topics",
      "problemMatcher": []
    },
    {
      "label": "pubsub: bootstrap",
      "dependsOrder": "sequence",
      "dependsOn": [
        "pubsub: emulator start",
        "pubsub: topics init"
      ],
      "problemMatcher": []
    },
    {
      "label": "backend: infra bootstrap",
      "dependsOrder": "parallel",
      "dependsOn": [
        "docker: infra up",
        "pubsub: bootstrap"
      ],
      "problemMatcher": []
    }
  ]
}
